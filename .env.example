# Tauri dev server host (vite.config.ts)
TAURI_DEV_HOST=127.0.0.1

# TIDAL API debug logging (true/false)
VITE_DEBUG_TIDAL=false

# Spotify OAuth — get Client ID from https://developer.spotify.com/dashboard
# Add redirect URI: http://127.0.0.1:1420/spotify (or your dev URL)
VITE_SPOTIFY_CLIENT_ID=
VITE_SPOTIFY_REDIRECT_URI=

# Firebase — get config from Firebase Console → Project settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
